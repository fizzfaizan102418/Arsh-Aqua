rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // 1. Products: Publicly readable, allow create for seeding
    match /products/{productId} {
      allow read: if true;
      allow create: if isValidProduct(incoming());
      allow update, delete: if false;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'desc', 'price', 'img', 'size'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() <= 100
        && data.desc is string && data.desc.size() <= 1000
        && data.price is number && data.price >= 0
        && data.img is string && data.img.size() <= 1000
        && data.size is string && data.size.size() <= 50;
    }

    // 2. Orders: Publicly create-only
    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow read, update, delete: if false;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerPhone', 'address', 'items', 'totalAmount', 'status', 'createdAt'])
        && data.customerName is string && data.customerName.size() <= 100
        && data.customerPhone is string && data.customerPhone.size() <= 20
        && data.address is string && data.address.size() <= 500
        && data.items is list && data.items.size() > 0
        && data.totalAmount is number && data.totalAmount > 0
        && data.status == 'pending'
        && data.createdAt == request.time;
    }

    // 3. Contact Messages: Publicly create-only
    match /messages/{messageId} {
      allow create: if isValidMessage(incoming());
      allow read, update, delete: if false;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'phone', 'message', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.phone is string && data.phone.size() <= 20
        && data.message is string && data.message.size() <= 1000
        && data.createdAt == request.time;
    }
  }
}
