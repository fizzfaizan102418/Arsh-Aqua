{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A mineral water product offered by Arsh Aqua",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "size": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "price", "imageUrl"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for water products",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "address": { "type": "string" },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivering", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "address", "items", "totalAmount", "status"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "A message sent via the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "message"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Available water products"
    },
    "/orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/messages": {
      "schema": "ContactMessage",
      "description": "Messages from the contact form"
    }
  }
}
